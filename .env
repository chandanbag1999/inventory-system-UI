# API — goes through Vite proxy so HTTPS cert is not an issue
VITE_API_URL=/api/v1
VITE_WS_URL=ws://localhost:5252/ws

# App
VITE_APP_NAME=NexusOps
VITE_APP_VERSION=2.0.0

# Feature flags
VITE_ENABLE_WEBSOCKET=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PWA=false

# Real backend — no mocks
VITE_MOCK_API=false
