# API Configuration
VITE_API_URL=http://localhost:5000/api/v1
VITE_WS_URL=ws://localhost:5000/ws

# App Config
VITE_APP_NAME=NexusOps
VITE_APP_VERSION=2.0.0

# Auth
VITE_JWT_SECRET=your-secret-key-here
VITE_TOKEN_EXPIRY=15m
VITE_REFRESH_TOKEN_EXPIRY=7d

# Google Maps
VITE_GOOGLE_MAPS_KEY=your-google-maps-key

# Feature Flags
VITE_ENABLE_WEBSOCKET=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PWA=false

# Enable Mock API for development
VITE_MOCK_API=true